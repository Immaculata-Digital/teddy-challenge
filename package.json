{
  "name": "@teddy-challenge/source",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start:frontend": "nx serve front-end",
    "start:backend": "cd back-end && ts-node -r tsconfig-paths/register -P tsconfig.app.json src/main.ts",
    "start:backend:watch": "cd back-end && ts-node-dev -r tsconfig-paths/register --respawn --transpile-only -P tsconfig.app.json src/main.ts",
    "stop:backend": "lsof -ti :3000 | xargs kill -9 2>/dev/null || true",
    "restart:backend": "npm run stop:backend && npm run start:backend",
    "build:frontend": "nx build front-end",
    "build:backend": "nx build api",
    "test": "nx run-many --target=test --all",
    "test:frontend": "nx test front-end",
    "test:backend": "nx test api",
    "test:affected": "nx affected --target=test",
    "test:coverage": "nx run-many --target=test --all --coverage",
    "lint": "nx run-many --target=lint --all",
    "lint:frontend": "nx lint front-end",
    "lint:backend": "nx lint api",
    "lint:affected": "nx affected --target=lint",
    "lint:fix": "nx run-many --target=lint --all -- --fix",
    "typeorm": "TS_NODE_PROJECT=back-end/tsconfig.app.json ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "npm run typeorm -- migration:generate -d back-end/src/database/data-source.ts",
    "migration:run": "npm run typeorm -- migration:run -d back-end/src/database/data-source.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d back-end/src/database/data-source.ts",
    "build:all": "nx run-many --target=build --all",
    "build:affected": "nx affected --target=build",
    "graph": "nx graph",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "affected:apps": "nx affected:apps",
    "affected:libs": "nx affected:libs",
    "nx": "nx"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/typeorm": "^10.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "axios": "^1.15.2",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.13.3",
    "prom-client": "^15.1.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20",
    "uuid": "^9.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.15",
    "@nx/js": "22.7.0",
    "@nx/nest": "^22.7.0",
    "@nx/node": "^22.7.0",
    "@nx/playwright": "^22.7.1",
    "@nx/react": "^22.7.0",
    "@nx/vite": "^22.7.0",
    "@nx/webpack": "^22.7.0",
    "@nx/workspace": "22.7.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.13",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^4.1.5",
    "jest": "^29.7.0",
    "jsdom": "^29.1.0",
    "nx": "22.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "vite": "^6.2.2",
    "vitest": "^3.0.9",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4"
  }
}
