{
  "name": "api",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "back-end/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "target": "node",
        "compiler": "tsc",
        "outputPath": "dist-api",
        "main": "back-end/src/main.ts",
        "tsConfig": "back-end/tsconfig.app.json",
        "webpackConfig": "back-end/webpack.config.js",
        "assets": ["back-end/src/assets"],
        "generatePackageJson": true
      },
      "configurations": {
        "development": {
          "optimization": false,
          "extractLicenses": false
        },
        "production": {
          "optimization": true,
          "extractLicenses": true
        }
      }
    },
    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/dist/back-end/package.json",
        "{workspaceRoot}/dist/back-end/package-lock.json"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": ["{workspaceRoot}/dist-api/workspace_modules"],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
      "executor": "nx:noop"
    },
    "serve": {
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "api:build",
        "watch": false,
        "inspect": false
      },
      "configurations": {
        "development": {
          "buildTarget": "api:build:development",
          "watch": false,
          "inspect": false
        },
        "production": {
          "buildTarget": "api:build:production",
          "watch": false,
          "inspect": false
        }
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/back-end"],
      "options": {
        "jestConfig": "back-end/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "tags": []
}
