{
  "name": "front-end-e2e",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "front-end-e2e/src",
  "implicitDependencies": ["front-end"],
  "tags": [],
  "// targets": "to see all targets run: nx show project front-end-e2e --web",
  "targets": {
    "e2e": {
      "executor": "@nx/playwright:playwright",
      "outputs": ["{workspaceRoot}/dist/.playwright/front-end-e2e"],
      "options": {
        "config": "front-end-e2e/playwright.config.ts"
      },
      "configurations": {
        "production": {
          "devServerTarget": "front-end:serve:production"
        }
      }
    }
  }
}
